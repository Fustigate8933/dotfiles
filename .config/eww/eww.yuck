(defwindow bar1
  :monitor 0
  :geometry (geometry
    :x "0%"
    :y "0.5%"
    :width "100%"
    :height "3%"
    :anchor "top center"
  )
  :stacking "fg"
  :windowtype "dock"
  :wm-ignore false
  :exclusive true
  (stuff)
)

