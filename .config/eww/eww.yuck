(defwidget stuff []
  (centerbox
    :class "bar"
    :orientation "h"
    (left)
    (middle)
    (right)
  )
)

(defwidget left []
  (box
    :spacing 7
    :orientation "horizontal"
    :halign "start"
    :space-evenly false
    :valign "center"
    (workspaces)
    (pc_stats)
    (weather)
	(window_title)
  )
)

(defvar show_calendar false)

(defwidget middle []
  (box
    :orientation "horizontal"
    :halign "center"
    :valign "center"
    (button
      :class "time"
      :onmiddleclick "~/.config/eww/scripts/update_calendar.sh"
      "${time.week}, ${time.month} ${time.day}, ${time.hour} : ${time.min} : ${time.second}"
    )
  )
)

(defwidget right []
  (box
    :halign "end"
    :spacing 7
	:space-evenly false
	(cava)
    (quick_launchers)
    (box
      :orientation "horizontal"
      :halign "end"
      :valign "center"
      :spacing 6
      :class "right"
      :space-evenly false
      (systray :icon-size 18 :spacing 2 :pack-direction "right")
	  (asus_profile_btn)
      (battery
        :status {EWW_BATTERY.BAT0.status}
        :battery {EWW_BATTERY.BAT0.capacity}
        :charging "󰠠 "
        :one " "
        :two " "
        :three " "
        :four " "
        :five " "
        :six " "
        :seven " "
      )
	  (dnd)
	  (microphone_status)
      (pavu)
      (volume_slider)
      (eventbox
        :class "btns-box"
        :onrightclick "~/.config/eww/scripts/launch_more_power_options.sh"
        " "
      )
    )
  )
)

(defpoll time
  :interval "0.5s" `date +'{"hour":"%H","min":"%M","second":"%S","week":"%a","month":"%b","day":"%d"}'`
)

(defpoll net
  :interval "60s"
  `nmcli -terse -fields SIGNAL,ACTIVE device wifi | awk --field-separator ':' '{if($2=="yes")print$1}';~/.wechat_monitor_hyprland.sh`
)

(defvar hover_battery false)

(defwidget battery [battery status one two three four five six seven charging]
  (box
    :class "bat-box"
    :vexpand true
    :valign "center"
	:tooltip `${EWW_BATTERY.BAT0.capacity}%`
      (box
        :vexpand true
        :valign "center"
        (label :text {
          status == "Charging" ? charging :
          battery < 14 ? seven :
          battery < 28 ? six :
          battery < 42 ? five :
          battery < 56 ? four :
          battery < 70 ? three :
          battery < 84 ? two : one
        })
      )
  )
)


(defvar show_more_power_options false)

(defwidget network [strength offline excellent good okay slow]
  (box
    :class "net-box"
    :vexpand true
    :halign "end"
    (label :text {
      strength == "" ? offline :
      strength < 20 ? slow :
      strength < 40 ? okay :
      strength < 60 ? good : excellent
    })
  )
)

(deflisten mic_state :initial "True" "~/.config/eww/scripts/get_microphone.sh")
(defwidget microphone_status []
	(box			
		:class "mic-state"
		(eventbox
			:onclick "~/.config/eww/scripts/toggle_microphone.sh"
			(label :text {
				mic_state == "True" ? "󰍬" : "󰍭"
			})
		)
	)
)

(deflisten dnd_state :initial "False" "~/.config/eww/scripts/get_dnd.sh")
(defwidget dnd []
	(box			
		:class "dnd-state"
		(eventbox
			:onclick "~/.config/eww/scripts/toggle_dnd.sh"
			(label :text {
				dnd_state == "False" ? "󰂜 " : "󰪑 "
			})
		)
	)
)


(deflisten asus_profile :initial "Detecting..." "~/.config/eww/scripts/get_asusctl_profile.sh")
(defwidget asus_profile_btn []
  (box
	:tooltip `${asus_profile}`
    (label :text "󱑭 ")
  )
)

(deflisten workspace_list :initial "[]" "~/.config/eww/scripts/get_workspaces.sh")
(deflisten active_workspace :initial "99" "~/.config/eww/scripts/get_active_workspaces.sh")
(defwidget workspaces []
  (eventbox :onscroll "~/.config/eww/scripts/change_active_workspace.sh {} ${active_workspace}"
    (box
      :class "workspace-box"
      :vexpand true
      :halign "start"
      (box
        :orientation "h" ; Make sure the box is oriented vertically
        :vexpand true
		:spacing 9
        (for workspace in workspace_list
          (eventbox :onclick "hyprctl dispatch workspace ${workspace.id}"
            :vexpand true
			(box
			  :class "${workspace.id == active_workspace ? 'active' : 'inactive'}"
			  :vexpand true
			  (label :vexpand true :hexpand true :class "" :text "${workspace.id == active_workspace ? workspace.id : workspace.id}")
			)
          )
        )
      )
    )
  )
)

(defwidget pavu []
  (eventbox
    :onhover "eww update show_volume=true"
    :onhoverlost "eww update show_volume=false"
    :onscroll "~/.config/eww/scripts/change_volume.sh {}"
    (button
      :onclick "pavucontrol &"
      :vexpand false
      :hexpand false
      :halign "end"
      :class "pavu"
      (label :text " ")
    )
  )
)

(defwindow cal
  :monitor 0
  :geometry (geometry
    :x "0%"
    :y "4px"
    :anchor "top center"
  )
  :stacking "overlay"
  :windowtype "normal"
  :exclusive false
  (calendar
    :class "calendar"
	:show-details true
	:show-heading true
	:onclick "~/.config/eww/scripts/date_click.sh {0} {1} {2}"
  )
)

(defwindow more_power_options
  :monitor 0
  :geometry (geometry
    :x "1%"
    :y "3px"
    :anchor "top right"
  )
  :stacking "overlay"
  :windowtype "normal"
  :exclusive false
  (box
    :class "btns-box-window"
    :spacing 5
    :orientation "v"
    (button :class "logout-icon" :onclick "loginctl kill-session self" "󰍂")
    (button :class "red" :onclick "poweroff" "󰐥")
    (button :class "green" :onclick "reboot" "")
  )
)

(deflisten win_title_text :initial "" "./scripts/get_current_window_title.sh")
(defwidget window_title []
  (literal :content '${strlength(win_title_text) != 0 ? '(box :class "window-title" (label :text {win_title_text}))' : ''}')
)

(deflisten volume :initial "0" "./scripts/get_volume.sh")

(defvar show_volume false)

(defwidget volume_slider []
  (box
    :class "volume-box"
    (revealer
      :visible true
      :transition "slideright"
      :reveal true
      :duration 500
      (scale
        :value volume
        :min -5.0
        :max 150.0
        :active true
        :orientation "h"
        :class "volume-slider"
      )
    )
  )
)

(deflisten cpu :interval "5s" :initial "50" "~/.config/eww/scripts/get_cpu.sh")
(defwidget cpu_progress []
  (box :class "overlay"
    :vexpand true
    :halign "left"
    :tooltip "cpu"
    (overlay
      (circular-progress
        :class "stat-background"
        :value 100
        :start-at 25
        :clockwise true
        :thickness "36"
        " "
      )
      (circular-progress
        :class "stat-progress"
        :value cpu
        :start-at 25
        :clockwise true
        :thickness "5"
        (label :class "progress-text" :text "")
      )
    )
  )
)


(defpoll ram :interval "5s" "~/.config/eww/scripts/get_memory.sh --used")
(defwidget ram_progress []
  (box :class "overlay"
    :vexpand true
    :halign "left"
    :tooltip "ram"
    (overlay
      (circular-progress
        :class "stat-background"
        :value 100
        :start-at 25
        :clockwise true
        :thickness "36"
        " "
      )
      (circular-progress
        :class "stat-progress"
        :value ram
        :start-at 25
        :clockwise true
        :thickness "5"
        (label :class "progress-text" :text "")
      )
    )
  )
)

(defwidget pc_stats []
  (box
    :class "pc-stats"
    :space-evenly false
    :vexpand true
    :halign "center"
    :spacing 8
    (cpu_progress)
    (ram_progress)
  )
)

(deflisten weather :initial "null" "python ./scripts/get_weather.py")
(deflisten weather_nanjing :initial "null" "python ./scripts/get_nanjing_weather.py")
(deflisten weather_irvine :initial "null" "python ./scripts/get_waterloo_weather.py")
(defwidget weather []
  (box :orientation "h" :space-evenly true :class "weather"
    (label :class "weather-error" :text " " :visible {weather == "null" ? true : false})
    (box
      :tooltip "Hsinchu"
      :visible {weather == "null" ? false : true}
      (label :class "weather-icon" :text {weather.icon})
      (label :class "weather-temp" :text {weather.temp})
    )
    (box
      :tooltip "Waterloo, CA"
      :visible {weather == "null" ? false : true}
      (label :class "weather-icon" :text {weather_irvine.icon})
      (label :class "weather-temp" :text {weather_irvine.temp})
    )
  )
)

(deflisten cava "~/.config/eww/scripts/cava-internal.sh")
(defwidget cava []
	(box
		:class "cava"
		:valign "center"
		:halign "end"
		(label :text cava)
	)
)

(defwidget quick_launchers []
  (box
    :class "quick-launchers"
    :valign "center"
    :halign "end"
	:space-evenly false
	:spacing 4
    (eventbox
      :onclick "./scripts/launch_scrcpy.sh"
      :class "white"
      :tooltip "Scrcpy"
      (label :text "󰄙 ")
    )
	(eventbox
	  :onclick "./scripts/launch_image.sh /mnt/ianch-Secondary/Downloads/Images/schedule.png"
	  :class "blue"
	  :tooltip "Class Schedule"
	  (label :text " ")
	)
    (eventbox
      :onclick "./scripts/launch_color_picker.sh"
      :class "red"
      :tooltip "Color Picker"
      (label :text " ")
    )
    (eventbox
      :onclick "./scripts/launch_calc.sh"
      :class "white"
      :tooltip "Calculator"
      (label :text " ")
    )
  )
)

(defwidget timer []
  (box
    :class "quick-launchers"
    :valign "center"
    :halign "end"
	(eventbox
	  :onclick "./scripts/launch_image.sh /mnt/ianch-Secondary/Downloads/Images/schedule.jpg"
	  :class "blue"
	  :tooltip "Class Schedule"
	  (label :text " ")
	)
    (eventbox
      :onclick "./scripts/launch_color_picker.sh"
      :class "red"
      :tooltip "Color Picker"
      (label :text " ")
    )
    (eventbox
      :onclick "./scripts/launch_calc.sh"
      :class "white"
      :tooltip "Calculator"
      (label :text " ")
    )
  )
)
